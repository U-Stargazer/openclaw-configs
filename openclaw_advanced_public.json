    "ollama pull qwen3:7b          # fast-autocomplete agent",
    "ollama pull deepseek-v3.2     # security agent",
    "ollama pull llama3.3          # docs-writer agent",
    "ollama pull glm-4.7-flash     # orchestrator / general agent",
    "ollama pull qwen3-coder       # code agent",
    "ollama pull llava             # multimodal fallback"
  ],
  "//_hardware": "Tuned for a 16GB RAM machine with WSL2. Adjust parallelAgents, cpuQuota, and Docker memory limits to your specs.",
  "//public-note": "Community config \u2014 safe to share. All paths use %USERNAME% (Windows env var). Provide your own API keys via environment variables. Adjust hardware limits to your machine specs."
}